# ==============================================
# Graphisme by ELECTRON - Environment Variables
# ==============================================

# Node Environment
NODE_ENV=development

# Database (SQLite for local, PostgreSQL for production)
DATABASE_URL="file:./dev.db"

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# AI Services (Ollama)
OLLAMA_API_URL=http://localhost:11434
# Available models: llama3.2, llama3.1:8b, qwen2.5-coder:7b, phi3:mini
OLLAMA_MODEL=llama3.2

# n8n Workflow Automation
N8N_API_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key

# Open WebUI
OPEN_WEBUI_URL=http://localhost:8080
OPEN_WEBUI_API_KEY=your-open-webui-api-key

# Email Service (Resend, SendGrid, etc.)
EMAIL_API_KEY=your-email-api-key
EMAIL_FROM=noreply@graphisme.electron
EMAIL_FROM_NAME=Graphisme by ELECTRON

# Redis Cache
REDIS_URL=redis://localhost:6379

# File Storage (S3, Cloudinary, etc.)
STORAGE_PROVIDER=local
STORAGE_PATH=./public/uploads

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# ==============================================
# Production Only (do not commit)
# ==============================================
# DATABASE_URL=postgresql://...
# NEXTAUTH_SECRET=...
